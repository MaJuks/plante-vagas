generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Address {
  id              Int           @id @default(autoincrement())
  country         String?
  state           String?
  city            String
  district        String
  street          String
  number          String
  complement      String?
  postalCode      String
  userCandidateId Int           @unique
  UserCandidate   UserCandidate @relation(fields: [userCandidateId], references: [id], onDelete: Cascade)
}

model UserCandidate {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  name          String
  dateNasc      DateTime
  cpf           String   @unique
  phone         String
  gender        String
  disablePerson String
  createdAt     DateTime @default(now())
  Address       Address?
  curriculo Curriculo?

}

model AddressCompany {
  id              Int           @id @default(autoincrement())
  country         String?
  state           String?
  city            String
  district        String
  street          String
  number          String
  complement      String?
  postalCode      String
  userCompanyId   Int           @unique
  userCompany     UserCompany @relation(fields: [userCompanyId], references: [id], onDelete: Cascade)
}

model UserCompany {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  name          String
  openingDate   DateTime
  cnpj          String   @unique
  description   String
  socialReason  String
  fantasyName   String
  phone         String
  createdAt     DateTime @default(now())
  Address       AddressCompany?
}


model Curriculo {
  id        Int @id @default(autoincrement())

  usuarioId Int @unique
  usuario   UserCandidate @relation(fields: [usuarioId], references: [id])

  experiencias   ExperienciaProfissional[]
  formacoes      FormacaoAcademica[]
  certificados   Certificado[]
  idiomas        Idioma[]
  diferenciais   Diferencial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExperienciaProfissional {
  id            Int @id @default(autoincrement())
  cargo         String
  empresa       String
  descricao     String
  inicioData    DateTime
  fimData       DateTime?
  empregoAtual  Boolean @default(false)

  curriculoId Int
  curriculo   Curriculo @relation(fields: [curriculoId], references: [id], onDelete: Cascade)
}

model FormacaoAcademica {
  id              Int @id @default(autoincrement())
  nivelFormacao   String
  grauFormacao    String
  curso           String
  nomeInstituicao String
  status          String
  inicioData      DateTime
  fimData         DateTime?

  curriculoId Int
  curriculo   Curriculo @relation(fields: [curriculoId], references: [id], onDelete: Cascade)
}

model Certificado {
  id              Int @id @default(autoincrement())
  nomeInstituicao String
  descricao       String
  dataEmissao     DateTime

  curriculoId Int
  curriculo   Curriculo @relation(fields: [curriculoId], references: [id], onDelete: Cascade)
}

model Idioma {
  id     Int @id @default(autoincrement())
  idioma String
  nivel  String

  curriculoId Int
  curriculo   Curriculo @relation(fields: [curriculoId], references: [id], onDelete: Cascade)
}

model Diferencial {
  id        Int @id @default(autoincrement())
  descricao String

  curriculoId Int
  curriculo   Curriculo @relation(fields: [curriculoId], references: [id], onDelete: Cascade)
}



enum Gender {
  MALE
  FEMALE
  OTHER
}

